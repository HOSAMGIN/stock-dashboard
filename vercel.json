{
  "version": 2,
  "builds": [
    {
      "src": "artifacts/api-server/dist/index.cjs",
      "use": "@vercel/node",
      "config": {
        "buildCommand": "pnpm --filter @workspace/api-server run build"
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "artifacts/api-server/dist/index.cjs" }
  ]
}
