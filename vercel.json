{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "builds": [
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": ["artifacts/api-server/src/**"] }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "artifacts/api-server/src/index.ts" }
  ]
}
